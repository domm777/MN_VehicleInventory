{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApiKey": "5214eee0-0f8c-407b-9bc4-3b33db2030a2",
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "vehicles-route": {
        "ClusterId": "vehicles-cluster",
        "Match": {
          "Path": "/vehicles-service/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" },
          {
            "RequestHeader": "X-From-Gateway",
            "Set": "true"
          }
        ]
      },
      "maintenance-route": {
        "ClusterId": "maintenance-cluster",
        "Match": {
          "Path": "/maintenance-service/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" },
          {
            "RequestHeader": "X-From-Gateway",
            "Set": "true"
          }
        ]
      }
    },
    "Clusters": {
      "vehicles-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5056" }
        }
      },
      "maintenance-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://maintenance-webapi-8928473-gma7ghhbdxfjhmd3.canadacentral-01.azurewebsites.net"
          }
        }
      }
      //"carRental-cluster": {
